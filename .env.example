# ==============================
# SERVIDOR
# ==============================
PORT=3333
HOST=0.0.0.0
NODE_ENV=production
LOG_LEVEL=info

# ==============================
# BANCO DE DADOS
# ==============================
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/globalengenharia
POSTGRES_DB=globalengenharia
POSTGRES_USER=globalengenharia
POSTGRES_PASSWORD=

# ==============================
# REDIS
# ==============================
REDIS_URL=redis://:PASSWORD@localhost:6379
REDIS_PASSWORD=

# ==============================
# JWT
# ==============================
JWT_SECRET=
JWT_REFRESH_SECRET=

# ==============================
# WHATSAPP — META CLOUD API
# ==============================
META_PHONE_NUMBER_ID=
META_WHATSAPP_TOKEN=
META_VERIFY_TOKEN=
META_APP_SECRET=
# Nome do template aprovado no Meta Business Manager usado para enviar o Pix
# de cobranca automaticamente quando uma OS e concluida (parametros: numero
# da OS, valor formatado e codigo Pix copia-e-cola, nessa ordem). Precisa ser
# criado e aprovado na Meta antes de funcionar em producao.
WHATSAPP_TEMPLATE_PIX_COBRANCA=pix_cobranca

# ==============================
# OPENAI
# ==============================
OPENAI_API_KEY=
OPENAI_STT_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

# ==============================
# ANTHROPIC (Claude)
# ==============================
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# ==============================
# MERCADO PAGO
# ==============================
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# ==============================
# SMTP (E-mail)
# ==============================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@DOMINIO

# ==============================
# ADMINISTRACAO
# ==============================
ADMIN_EMAIL=

# ==============================
# ARMAZENAMENTO
# ==============================
STORAGE_DIR=/app/storage

# ==============================
# FRONTEND
# ==============================
FRONTEND_URL=https://app.DOMINIO
