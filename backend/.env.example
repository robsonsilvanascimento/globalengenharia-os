# Servidor
PORT=3333
NODE_ENV=development

# Armazenamento de arquivos: por padrao usa uma pasta local "storage/" na
# raiz do backend (implementacao ArmazenamentoLocalService). Pode ser trocado
# no futuro por uma implementacao de nuvem (S3, etc.) sem mudar quem consome
# o servico, bastando implementar a interface ArmazenamentoArquivoService.
STORAGE_DIR="storage"

# Banco de dados
DATABASE_URL="postgresql://user:password@localhost:5432/os_whatsapp?schema=public"

# Redis / filas (BullMQ)
REDIS_URL="redis://localhost:6379"

# Autenticacao
JWT_SECRET="troque-esta-chave-em-producao"
JWT_REFRESH_SECRET="troque-esta-chave-de-refresh-em-producao"

# URL do frontend, usada para montar o link enviado no e-mail de
# redefinicao de senha (ex: ${FRONTEND_URL}/redefinir-senha?token=...).
# Default se nao definido: http://localhost:5173
FRONTEND_URL="http://localhost:5173"

# WhatsApp Cloud API (Meta)
META_WHATSAPP_TOKEN=""
META_PHONE_NUMBER_ID=""
META_VERIFY_TOKEN=""
META_APP_SECRET=""

# Nome do template (aprovado na Meta) do lembrete de agendamento enviado ~24h
# antes da visita. O template deve ter 2 parametros no corpo:
# {{1}} = numero da OS, {{2}} = data/hora do agendamento.
META_TEMPLATE_LEMBRETE_AGENDAMENTO="lembrete_agendamento"

# Template avisando o cliente que o tecnico esta a caminho. Deve ter 2
# parametros no corpo: {{1}} = numero da OS, {{2}} = situacao ("a caminho").
META_TEMPLATE_TECNICO_A_CAMINHO="tecnico_a_caminho"

# Anthropic (respostas de IA da FAQ para o bot do WhatsApp)
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-haiku-4-5-20251001"

# OpenAI (transcricao de audio/voice notes do WhatsApp - chave separada da Anthropic acima)
OPENAI_API_KEY=""
OPENAI_STT_MODEL="whisper-1"
OPENAI_TTS_MODEL="tts-1"
OPENAI_TTS_VOICE="alloy"

# E-mail (SMTP generico - Gmail, Outlook, Zoho, etc.)
SMTP_HOST="smtp.exemplo.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Sistema OS <no-reply@empresa.com>"
