{
  "name": "os-whatsapp-backend",
  "version": "0.1.0",
  "description": "Backend do Sistema de Ordens de Servico com chatbot WhatsApp",
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/main/server.ts",
    "dev:worker": "tsx watch src/main/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main/server.js",
    "start:worker": "node dist/main/worker.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@prisma/client": "^5.20.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.21.2",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "expo-server-sdk": "^3.15.0",
    "fastify": "^4.28.1",
    "googleapis": "^173.0.0",
    "ioredis": "5.10.1",
    "jsonwebtoken": "^9.0.2",
    "mercadopago": "^2.0.0",
    "nodemailer": "^6.9.15",
    "openai": "^6.46.0",
    "pdfkit": "^0.15.1",
    "pino": "^9.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.14.15",
    "@types/nodemailer": "^6.4.16",
    "@types/pdfkit": "^0.13.4",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "pino-pretty": "^11.2.2",
    "prisma": "^5.20.0",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4",
    "vitest": "^4.1.10"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "allowScripts": {
    "@prisma/client@5.22.0": true,
    "@prisma/engines@5.22.0": true,
    "bcrypt@5.1.1": true,
    "esbuild@0.28.1": true,
    "msgpackr-extract@3.0.4": true,
    "prisma@5.22.0": true
  }
}
